{
  "name": "pi-spotify-widget",
  "version": "0.1.4",
  "description": "Lightweight Spotify Now Playing widget for Pi Coding Agent.",
  "type": "module",
  "license": "MIT",
  "author": "eiei114",
  "keywords": [
    "pi-package",
    "pi",
    "agent-skill",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-spotify-widget.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-spotify-widget/issues"
  },
  "homepage": "https://github.com/eiei114/pi-spotify-widget#readme",
  "files": [
    "extensions/",
    "lib/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "skills/"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run typecheck && npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills/spotify-playback"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "typebox": "latest",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
